      "",
      "  // ─── Derived Values ───────────────────────────────────────────────────────",
      "  const derivedValue = data?.filter(item => item.active);",
      "",
      "  // ─── Fetch Data ───────────────────────────────────────────────────────────",
      "  useEffect(() => {",
