      "}, [${2:dependency}]);"
    ]
  },

  // ===========================================================
  // 🔀 EARLY RETURNS
  // ===========================================================

  // er-load → early return while loading
  "Early Return Loading": {
    "prefix": "er-load",
    "body": "if (isLoading) return <p className=\"text-sm text-muted-foreground\">Loading...</p>;"
  },

  // er-error → early return on error
  "Early Return Error": {
    "prefix": "er-error",
    "body": "if (error) return <p className=\"text-sm text-red-500\">{error}</p>;"
  },

  // er-empty → early return on empty list
  "Early Return Empty": {
    "prefix": "er-empty",
    "body": "if (!${1:items}?.length) return <p className=\"text-sm text-muted-foreground\">${2:Nothing here yet.}</p>;"
  },

  // ===========================================================
  // 🛠️ UTILITY (ADDITIONAL)
  // ===========================================================

  // hsubmit → form submit handler with trim + guard
  "Handler Submit": {
    "prefix": "hsubmit",
    "body": [
      "function handleSubmit(e: React.FormEvent) {",
      "  e.preventDefault();",
      "  const trimmed = ${1:value}.trim();",
      "  if (!trimmed) return;",
      "  ${2:onAction}(trimmed);",
      "  ${3:setValue('');}",
      "}"
    ]
  },

  // maplist → map over array to render components
  "Map List": {
    "prefix": "maplist",
    "body": [
      "{${1:items}.map((${2:item}) => (",
      "  <${3:Component}",
      "    key={${2:item}.id}",
      "    $0",
      "  />",
      "))}"
    ]
  }
}
