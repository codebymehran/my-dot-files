      "        setData(response.data);",
      "        setError(null);",
      "      } catch (err) {",
      "        setError((err as Error).message);",
      "        setData(null);",
      "      } finally {",
      "        setIsLoading(false);",
      "      }",
      "    }",
      "    loadData();",
      "  }, []);",
      "",
      "  // ─── Handlers ─────────────────────────────────────────────────────────────",
